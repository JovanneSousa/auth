@page "/sistemas"

@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject IApiService _apiService
@inject HttpClient httpClient

@using Auth.Client.Dialogs;
@using System.Net.Http.Json

@if (_sistemas == null)
{
    <p><em>Loading...</em></p>
} else 
{
    <MudStack Spacing="4">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
            <MudText Typo="Typo.h5">Sistemas</MudText>
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Add"
                       OnClick="NovoSistemaAsync">
                Novo sistema
            </MudButton>
        </MudStack>

        <MudExpansionPanels MultiExpansion="true">
            @foreach (var sistema in _sistemas)
            {
                <MudExpansionPanel>
                    <TitleContent>
                        <MudStack Row="true" Justify="Justify.SpaceBetween"
                                  AlignItems="AlignItems.Center" Style="width:100%; padding-right:8px;">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                                <MudAvatar Color="Color.Primary" Variant="Variant.Filled" Size="Size.Medium">
                                    @Initials(sistema.Name)
                                </MudAvatar>
                                <div>
                                    <MudText Typo="Typo.subtitle1" Style="font-weight:500">@sistema.Name</MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@sistema.Url</MudText>
                                </div>
                            </MudStack>
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined">
                                    @sistema.Permissoes.Count role(s)
                                </MudChip>
                                <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                               Title="Editar sistema"
                                               OnClick="() => OpenSistemaDialog(sistema)" />
                                <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                               Size="Size.Small" Color="Color.Error"
                                               OnClick="() => RemoverSistema(sistema)" />
                            </MudStack>
                        </MudStack>
                    </TitleContent>

                    <ChildContent>
                        <MudTabs Elevation="0" Rounded="false" PanelClass="pa-4"
                                 ApplyEffectsToContainer="true" Color="Color.Primary">

                            <MudTabPanel Text="Roles e Claims">
                                <MudStack Spacing="3">
                                    @foreach (var role in sistema.Permissoes)
                                    {
                                        <MudCard Outlined="true" Elevation="0">
                                            <MudCardHeader Style="padding:10px 14px; background:var(--mud-palette-background-grey)">
                                                <CardHeaderContent>
                                                    <MudText Typo="Typo.subtitle2">@role.Name</MudText>
                                                </CardHeaderContent>
                                                <CardHeaderActions>
                                                    <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                                   Size="Size.Small" Color="Color.Error"
                                                                   OnClick="() => RemoverRole(sistema, role)" />
                                                </CardHeaderActions>
                                            </MudCardHeader>

                                            <MudCardContent Style="padding:12px 14px">
                                                @{
                                                    var claims = _claimsPorRole.GetValueOrDefault(role.Id, new());
                                                }
                                                <MudText Typo="Typo.overline" Color="Color.Secondary" Class="mb-2">
                                                    Claims (@claims.Count)
                                                </MudText>

                                                <MudGrid Spacing="1">
                                                    @foreach (var claim in claims)
                                                    {
                                                        <MudItem>
                                                            <MudChip T="string"
                                                                     Size="Size.Small"
                                                                     Variant="Variant.Outlined"
                                                                     OnClose="() => RemoverClaim(role.Id, claim)"
                                                                     CloseIcon="@Icons.Material.Filled.Close"
                                                                     Style="font-size:11px">
                                                                @claim.ClaimValue
                                                            </MudChip>
                                                        </MudItem>
                                                    }
                                                </MudGrid>

                                                <MudDivider Class="my-2" />

                                                @if (_roleComInputAberto == role.Id)
                                                {
                                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                                        <MudTextField @bind-Value="_novaClaimTexto"
                                                                      Placeholder="ex: usuarios:criar"
                                                                      Variant="Variant.Outlined"
                                                                      Margin="Margin.Dense"
                                                                      Style="min-width:200px; font-size:12px"
                                                                      @onkeydown="(e) => OnClaimKeyDown(e, role.Id)"
                                                                      Immediate="true" />
                                                        <MudIconButton Icon="@Icons.Material.Filled.Check"
                                                                       Size="Size.Small" Color="Color.Success"
                                                                       OnClick="() => ConfirmarClaim(role.Id)" />
                                                        <MudIconButton Icon="@Icons.Material.Filled.Close"
                                                                       Size="Size.Small"
                                                                       OnClick="CancelarClaim" />
                                                    </MudStack>
                                                }
                                                else
                                                {
                                                    <MudButton Size="Size.Small"
                                                               Variant="Variant.Text"
                                                               StartIcon="@Icons.Material.Filled.Add"
                                                               OnClick="() => AbrirInputClaim(role.Id)">
                                                        Adicionar claim
                                                    </MudButton>
                                                }
                                            </MudCardContent>
                                        </MudCard>
                                    }

                                    <MudStack Row="true" Justify="Justify.FlexEnd">
                                        <MudButton Variant="Variant.Outlined"
                                                   StartIcon="@Icons.Material.Filled.Add"
                                                   Size="Size.Small"
                                                   OnClick="() => OpenRoleDialog(sistema, null)">
                                            Nova role
                                        </MudButton>
                                    </MudStack>
                                </MudStack>
                            </MudTabPanel>

                            <MudTabPanel Text="Usuários">
                                @* TODO: Buscar usuários por sistema.Id e listar aqui *@
                                @* Sugestão de estrutura quando implementar:
                               foreach (var usuario in _usuariosPorSistema[sistema.Id])
                               {
                                   <MudStack Row AlignItems="Center">
                                       <MudAvatar>@Initials(usuario.Nome)</MudAvatar>
                                       <div>
                                           <MudText>@usuario.Nome</MudText>
                                           <MudText Typo="caption">@usuario.Email</MudText>
                                       </div>
                                       <MudChip>@usuario.RoleNome</MudChip>
                                   </MudStack>
                               }
                            *@
                                <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center"
                                          Style="padding: 2rem; opacity: 0.5">
                                    <MudIcon Icon="@Icons.Material.Filled.People" Size="Size.Large" />
                                    <MudText Typo="Typo.body2">Usuários serão listados aqui</MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                                        Implemente a busca de usuários por sistema e vincule a uma role.
                                    </MudText>
                                </MudStack>
                            </MudTabPanel>

                        </MudTabs>
                    </ChildContent>
                </MudExpansionPanel>
            }
        </MudExpansionPanels>
    </MudStack>
}

@code {
    private List<SystemViewModel> _sistemas;
    private Dictionary<string, List<ApplicationClaimViewModel>> _claimsPorRole = new();

    private string _roleComInputAberto;
    private string _novaClaimTexto = string.Empty;

    // ── Lifecycle ────────────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        var response = await _apiService.GetAsync<List<SystemViewModel>>("api/sistema");
        if (!response.Success || response.Data is null)
        {
            _sistemas = new();
            MostrarErros(response.Errors);
            return;
        }

        _sistemas = response.Data;
        foreach (var s in _sistemas)
            foreach (var role in s.Permissoes)
                _claimsPorRole[role.Id] = role.Claims;
    }
    #region claims
    private void AbrirInputClaim(string roleId)
    {
        _roleComInputAberto = roleId;
        _novaClaimTexto = "";
    }

    private void CancelarClaim()
    {
        _roleComInputAberto = null;
        _novaClaimTexto = "";
    }

    private async void ConfirmarClaim(string roleId)
    {
        var claim = new ApplicationClaimViewModel(roleId, _novaClaimTexto.Trim().ToUpper());
        if (string.IsNullOrWhiteSpace(claim.ClaimValue)) { CancelarClaim(); return; }

        var sucesso = await SalvaNovaClaim(claim);

        if (!_claimsPorRole.ContainsKey(roleId))
            _claimsPorRole[roleId] = new();

        if (!_claimsPorRole[roleId].Contains(claim) && sucesso)
            _claimsPorRole[roleId].Add(claim);

        CancelarClaim();
    }

    private async Task<bool> SalvaNovaClaim(ApplicationClaimViewModel claim)
    {
        var response = await _apiService.PostAsync<ApplicationClaimViewModel, bool>("api/sistema/claim", claim);
        if(!response.Success)
        {
            MostrarErros(response.Errors);
            return response.Success;
        }
        Snackbar.Add("Claim salva com sucesso!", Severity.Success);
        return true;
    }

    private async Task OnClaimKeyDown(KeyboardEventArgs e, string roleId)
    {
        if (e.Key == "Enter") ConfirmarClaim(roleId);
        if (e.Key == "Escape") CancelarClaim();
        await Task.CompletedTask;
    }

    private async void RemoverClaim(string roleId, ApplicationClaimViewModel claim)
    {
        bool? confirm = await DialogService.ShowMessageBoxAsync(
                title: "Confirmar exclusão",
                markupMessage: (MarkupString)$"Deseja excluir a claim <b>{claim.ClaimValue}</b> permanentemente?",
                yesText: "Excluir",
                noText: "Cancelar");

        if (confirm is not null && confirm == true)
        {
            try
            {
                var response = await httpClient.DeleteAsync($"api/sistema/claim/excluir/{roleId}/{claim.ClaimValue}");

                if (response.IsSuccessStatusCode)
                {
                    var result = await response.Content.ReadFromJsonAsync<ResponsePayload<bool>>();

                    if (result.Data && _claimsPorRole.TryGetValue(roleId, out var lista))
                    {
                        Snackbar.Add("Claim Excluida com sucesso!", Severity.Success);
                        lista.Remove(claim);
                        StateHasChanged();
                        return;
                    }
                } 
                var error = await response.Content.ReadFromJsonAsync<ResponseError<string>>();
                Snackbar.Add(error.Errors, Severity.Error);
            } catch (Exception ex)
            {
                Snackbar.Add(ex.Message, Severity.Error);
            }
        }
    }

    #endregion

    #region Roles

    private async Task OpenRoleDialog(SystemViewModel sistema, ApplicationRoleViewModel? role)
    {
        var parameters = new DialogParameters
        {
            ["sistema"] = sistema
        };
        var dialog = await DialogService.ShowAsync<CreateRoleDialog>("Nova role", parameters);

        var result = await dialog.Result;
        if (!result.Canceled && result.Data is ApplicationRoleViewModel r)
        {
            if (!sistema.Permissoes.Any(x => x.Id == r.Id))
            {
                sistema.Permissoes.Add(r);
                _claimsPorRole[r.Id] = new();
            }
            StateHasChanged();
        }
    }

    private void RemoverRole(SystemViewModel sistema, ApplicationRoleViewModel role)
    {
        sistema.Permissoes.Remove(role);
        _claimsPorRole.Remove(role.Id);
        // TODO: await SistemaService.DeleteRoleAsync(role.Id);
    }
    #endregion

    #region Systems
    private async Task NovoSistemaAsync()
    {
        var options = new DialogOptions
        {
            FullWidth = true
        };
        var dialog = await DialogService.ShowAsync<CreateSystemDialog>("", options);
        var result = await dialog.Result;

        if (!result.Canceled && result.Data is SystemViewModel novoSistema)
        {
            _sistemas.Add(novoSistema);
            StateHasChanged();
        }
    }

    private async Task RemoverSistema(SystemViewModel sys)
    {
        throw new NotImplementedException();
    }

    private async Task OpenSistemaDialog(SystemViewModel sistema)
    {
        var options = new DialogOptions
        {
            FullWidth = true
        };
        var parameters = new DialogParameters
        {
            ["Model"] = sistema,
        };
        var dialog = await DialogService.ShowAsync<CreateSystemDialog>( "Editar sistema", parameters, options);

        var result = await dialog.Result;
        if (!result.Canceled && result.Data is SystemViewModel s)
        {
            if (!_sistemas.Any(x => x.Id == s.Id))
                _sistemas.Add(s);
            StateHasChanged();
        }
    }
    #endregion

    // ── Helpers ──────────────────────────────────────────────────────────────
    private static string Initials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length >= 2
            ? $"{parts[0][0]}{parts[^1][0]}".ToUpper()
            : name[..Math.Min(2, name.Length)].ToUpper();
    }

    private async Task ImprimeErrosRetornoHttp(HttpResponseMessage response)
    {
        var error = await response.Content.ReadFromJsonAsync<ResponseError<string[]>>();
        foreach (var errorMessage in error.Errors)
            Snackbar.Add(errorMessage, Severity.Error);
    }

    private void MostrarErros(string[] erros)
    {
        foreach (var errorMessage in erros)
            Snackbar.Add(errorMessage, Severity.Error);
    }
}
