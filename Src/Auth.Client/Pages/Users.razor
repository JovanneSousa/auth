@page "/usuarios"

@inject IDialogService DialogService

@using Auth.Client.Dialogs;
@using System.Net.Http.Json
@inject HttpClient httpClient

@if (Usuarios == null )
{
    <p><em>Loading...</em></p>
} else
{
    <MudDataGrid 
        @ref="_elementGrid" 
        T="RegisterUserViewModel"
        Items="@Usuarios" 
        EditMode="@DataGridEditMode.Form"
        ReadOnly="false"
        StartedEditingItem="@StartedEditingItem" 
        CanceledEditingItem="@CanceledEditingItem" 
        CommittedItemChanges="@CommittedItemChanges"
        Bordered="true" 
        Dense="true" 
        EditTrigger="DataGridEditTrigger.Manual">

        <ToolBarContent>
            <MudText Typo="Typo.h6">Lista de usuarios</MudText>
            <MudSpacer />
            <MudButtonGroup Class="ma-0 pa-0" Color="Color.Success" Variant="Variant.Filled">
                <MudButton OnClick="NewItemAsync">
                    Criar Novo Usuario
                </MudButton>
            </MudButtonGroup>
        </ToolBarContent>
        <Columns>
            <TemplateColumn hidden="true">
                <EditTemplate>
                    @* Conteúdo extra exibido dentro do form de edição *@
                    <MudText Typo="Typo.h6" Class="mb-2">@titleModal()</MudText>
                </EditTemplate>
            </TemplateColumn>
            <PropertyColumn Property="x => x.Email" />
            <PropertyColumn Property="x => x.Nome" />
            <PropertyColumn Property="x => x.Profile" />
            <PropertyColumn Property="x => x.System" />

            <TemplateColumn Title="Ações" CellClass="d-flex justify-between">
                <CellTemplate>
                    <MudIconButton Size="@Size.Small" Icon="@Icons.Material.Outlined.Edit" OnClick="@context.Actions.StartEditingItemAsync" />
                    <MudIconButton Size="@Size.Small" Icon="@Icons.Material.Outlined.Delete" OnClick="@(() => DeleteItem(context.Item))" />
                </CellTemplate>
            </TemplateColumn>
        </Columns>
    </MudDataGrid>

}

@code {
    private List<RegisterUserViewModel> Usuarios;
    private List<string> _events = new();
    private MudDataGrid<RegisterUserViewModel> _elementGrid = default!;
    private bool isCreating;
    private string titleModal() => 
        isCreating ? "Criar um novo usuário" : "Editar usuário";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            ResponsePayload<IEnumerable<RegisterUserViewModel>> response =
                await httpClient.GetFromJsonAsync<ResponsePayload<IEnumerable<RegisterUserViewModel>>>("api/auth/listar-usuarios");
            Usuarios = response.Data.ToList();
        } catch
        {
            Usuarios = new List<RegisterUserViewModel>();
        }
    }

    private async Task NewItemAsync()
    {
        var elem = new RegisterUserViewModel();
        isCreating = true;
        await DialogService.ShowAsync<CreateUserDialog>();
    }

    private void DeleteItem(RegisterUserViewModel item)
    {
        Usuarios.Remove(item);
    }

    // events
    private void StartedEditingItem(RegisterUserViewModel item)
    {
        _events.Insert(0, $"Event = StartedEditingItem, Data = {System.Text.Json.JsonSerializer.Serialize(item)}");
    }

    private void CanceledEditingItem(RegisterUserViewModel item)
    {
        // update code for backing data here if needed
        _events.Insert(0, $"Event = CanceledEditingItem, Data = {System.Text.Json.JsonSerializer.Serialize(item)}");
        isCreating = false;
    }

    private Task<DataGridEditFormAction> CommittedItemChanges(RegisterUserViewModel item)
    {
        // update code for the backing data here
        _events.Insert(0, $"Event = CommittedItemChanges, Data = {System.Text.Json.JsonSerializer.Serialize(item)}");
        isCreating = false;

        return Task.FromResult(DataGridEditFormAction.Close);
    }

    public class ResponsePayload<T>
    {
        public bool Success { get; set; }
        public T Data { get; set; }
    }
}
