@page "/usuarios"

@inject IDialogService DialogService

@using Auth.Client.Dialogs;
@using System.Net.Http.Json
@inject HttpClient httpClient

@if (Usuarios == null)
{
    <p><em>Loading...</em></p>
}
else
{
    <MudDataGrid @ref="_elementGrid"
                 T="AuthUserViewModel"
                 Items="@Usuarios"
                 EditMode="@DataGridEditMode.Form"
                 ReadOnly="false"
                 Bordered="true"
                 Dense="true"
                 EditTrigger="DataGridEditTrigger.Manual"
                 RowClick="OnRowClick">

        <ToolBarContent>
            <MudText Typo="Typo.h6">Lista de usuarios</MudText>
            <MudSpacer />
            <MudButtonGroup Class="ma-0 pa-0" Color="Color.Success" Variant="Variant.Filled">
                <MudButton OnClick="NewItemAsync">
                    Criar Novo Usuario
                </MudButton>
            </MudButtonGroup>
        </ToolBarContent>
        <Columns>
            <PropertyColumn Property="x => x.Nome" />
            <PropertyColumn Property="x => x.Email" />
            <TemplateColumn Title="Sistemas">
                <CellTemplate Context="context">
                    @if (context.Item.Systems != null && context.Item.Systems.Any())
                    {
                        @string.Join(", ", context.Item.Systems.OrderBy(s => s.Name).Select(s => s.Name))
                    }
                    else
                    {
                        <MudText Color="Color.Secondary">Nenhum sistema</MudText>
                    }
                </CellTemplate>
            </TemplateColumn>

            <TemplateColumn Title="Ações" CellClass="d-flex justify-between">
                <CellTemplate>
                    <MudIconButton Size="@Size.Small" Icon="@Icons.Material.Outlined.Delete" OnClick="@(() => DeleteItem(context.Item))" />
                </CellTemplate>
            </TemplateColumn>
        </Columns>
    </MudDataGrid>

}

@code {
    private List<AuthUserViewModel> Usuarios;
    private List<string> _events = new();
    private MudDataGrid<AuthUserViewModel> _elementGrid = default!;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            ResponsePayload<IEnumerable<AuthUserViewModel>> response =
                await httpClient.GetFromJsonAsync<ResponsePayload<IEnumerable<AuthUserViewModel>>>("api/auth/listar-usuarios");
            Usuarios = response.Data.ToList();
        }
        catch
        {
            Usuarios = new List<AuthUserViewModel>();
        }
    }

    private async Task OnRowClick(DataGridRowClickEventArgs<AuthUserViewModel> args)
    {
        AuthUserViewModel user;

        try
        {
            ResponsePayload<AuthUserViewModel> response =
                await httpClient.GetFromJsonAsync<ResponsePayload<AuthUserViewModel>>($"api/auth/details-user/{args.Item.Id}");
            user = response.Data;
        }
        catch
        {
            user = new AuthUserViewModel
            {
                Email = "Erro ao buscar!",
                Id = "",
                Nome = "Erro ao buscar!",
                Systems = new()
            };
        }

        var parameters = new DialogParameters
        {
            ["Model"] = user
        };

        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.Medium,
            FullWidth = true
        };

        await DialogService.ShowAsync<DetailUserDialog>("Detalhes do Usuário", parameters, options);
    }

    private async Task NewItemAsync()
    {
        var options = new DialogOptions
        {
            FullWidth = true
        };
        var dialog = await DialogService.ShowAsync<CreateUserDialog>("", options);
        var result = await dialog.Result;

        if(!result.Canceled && result.Data is AuthUserViewModel novoUsuario)
        {
            Usuarios.Add(novoUsuario);
            StateHasChanged();
        }
    }

    private async Task DeleteItem(AuthUserViewModel item)
    {
        bool? confirm = await DialogService.ShowMessageBoxAsync(
                title: "Confirmar exclusão",
                markupMessage: (MarkupString)$"Deseja excluir o usuário <b>{item.Nome}</b> permanentemente?",
                yesText: "Excluir",
                noText: "Cancelar");

        if (confirm is not null && confirm == true)
        {
            var response = await httpClient.DeleteAsync($"api/auth/excluir/{item.Id}");

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<ResponsePayload<bool>>();

                if(result.Data)
                {
                    Usuarios.Remove(item);
                    StateHasChanged();
                }
            }
        }
    }
}
