@page "/usuarios"
@inject HttpClient Http

@using System.Net.Http.Json
@inject HttpClient httpClient

@if (Usuarios == null )
{
    <p><em>Loading...</em></p>
} else
{
    <MudDataGrid 
        @ref="_elementGrid" 
        T="AuthUserViewModel" 
        Items="@Usuarios" 
        EditMode="@DataGridEditMode.Form"
        ReadOnly="@_readOnly"
        StartedEditingItem="@StartedEditingItem" 
        CanceledEditingItem="@CanceledEditingItem" 
        CommittedItemChanges="@CommittedItemChanges"
        Bordered="true" 
        Dense="true" 
        EditTrigger="DataGridEditTrigger.Manual">

        <ToolBarContent>
            <MudText Typo="Typo.h6">Lista de usuarios</MudText>
            <MudSpacer />
            <MudButtonGroup Class="ma-0 pa-0" Color="Color.Success" Variant="Variant.Filled">
                <MudButton OnClick="NewItemAsync">
                    Criar Novo Usuario
                </MudButton>
            </MudButtonGroup>
        </ToolBarContent>
        <Columns>
            <PropertyColumn Property="x => x.Email" />
            <PropertyColumn Property="x => x.UserName" />
            <TemplateColumn Title="Ações" Hidden="@_readOnly" CellClass="d-flex justify-between">
                <CellTemplate>
                    <MudIconButton Size="@Size.Small" Icon="@Icons.Material.Outlined.Edit" OnClick="@context.Actions.StartEditingItemAsync" />
                    <MudIconButton Size="@Size.Small" Icon="@Icons.Material.Outlined.Delete" OnClick="@(() => DeleteItem(context.Item))" />
                </CellTemplate>
            </TemplateColumn>
        </Columns>
    </MudDataGrid>
}

@code {
    private List<AuthUserViewModel> Usuarios;
    private bool _readOnly;
    private List<string> _events = new();
    private MudDataGrid<AuthUserViewModel> _elementGrid = default!;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            ResponsePayload<IEnumerable<AuthUserViewModel>> response = 
                await httpClient.GetFromJsonAsync<ResponsePayload<IEnumerable<AuthUserViewModel>>>("api/auth/listar-usuarios");
            Usuarios = response.Data.ToList();
        } catch
        {
            Usuarios = new List<AuthUserViewModel>();
        }
    }

    private async Task NewItemAsync()
    {
        var elem = new AuthUserViewModel();
            await _elementGrid.SetEditingItemAsync(elem);
    }

    private void DeleteItem(AuthUserViewModel item)
    {
        Usuarios.Remove(item);
    }

    // events
    private void StartedEditingItem(AuthUserViewModel item)
    {
        _events.Insert(0, $"Event = StartedEditingItem, Data = {System.Text.Json.JsonSerializer.Serialize(item)}");
    }

    private void CanceledEditingItem(AuthUserViewModel item)
    {
        // update code for backing data here if needed
        _events.Insert(0, $"Event = CanceledEditingItem, Data = {System.Text.Json.JsonSerializer.Serialize(item)}");
    }

    private Task<DataGridEditFormAction> CommittedItemChanges(AuthUserViewModel item)
    {
        // update code for the backing data here
        _events.Insert(0, $"Event = CommittedItemChanges, Data = {System.Text.Json.JsonSerializer.Serialize(item)}");

        return Task.FromResult(DataGridEditFormAction.Close);
    }
    
    public class AuthUserViewModel
    {
        public string UserName { get; set; }
        public string Email { get; set; }
    }

    public class ResponsePayload<T>
    {
        public bool Success { get; set; }
        public T Data { get; set; }
    }
}
