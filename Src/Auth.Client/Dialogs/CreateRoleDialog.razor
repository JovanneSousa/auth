@using MudBlazor

@inject ISnackbar Snackbar

@inject IDialogService DialogService;
@inject IApiService _apiService;

<MudDialog>
    <DialogContent>
        <MudText Typo="Typo.h6">Criar novo perfil</MudText>

        <MudTextField @bind-Value="Model.Name"
                      Label="Nome" Required="true"
                      RequiredError="O nome é obrigatório" />
    </DialogContent>

    <DialogActions>
        <MudButton OnClick="Cancel">Cancelar</MudButton>
        <MudButton Color="Color.Primary" OnClick="Submit">Salvar</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    IMudDialogInstance MudDialog { get; set; }

    [Parameter]
    public SystemViewModel? Sistema { get; set; }

    [Parameter]
    public ApplicationRoleViewModel? Model { get; set; }

    protected override void OnParametersSet()
    {
        if (Model is null)
        {
            Model = new ApplicationRoleViewModel
            {
                Id = Guid.NewGuid().ToString(),
                SystemId = Sistema?.Id ?? string.Empty,
                Name = string.Empty,
                Claims = new()
            };
        }
    }


    private async Task Submit()
    {
        await SalvarRole(Model);
        MudDialog.Close(DialogResult.Ok(Model));
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    private async Task SalvarRole(ApplicationRoleViewModel role, CancellationToken ct = default)
    {
        var response = await _apiService.PostAsync<ApplicationRoleViewModel, bool>("/api/sistema/roles",role, ct);

        if (response.Success)
        {
            var novaRole = new ApplicationRoleViewModel
            {
                Id = role.Id,
                Name = role.Name,
                SystemId = role.SystemId,
                Claims = new(),
            };

            Snackbar.Add("Role criada com sucesso!", Severity.Success);

            MudDialog.Close(DialogResult.Ok(novaRole));

            return;
        }

        FechaDialogError(response.Errors);
    }

    private void FechaDialogError(string[] errors)
    {
        foreach (var error in errors)
            Snackbar.Add(error, Severity.Error);

        MudDialog.Close(DialogResult.Cancel);
    }
}
