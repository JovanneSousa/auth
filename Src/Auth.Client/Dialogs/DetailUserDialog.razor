@using MudBlazor

@inject IDialogService DialogService;
@inject HttpClient httpClient;

<MudDialog>
    <DialogContent>
        <MudTextField @bind-Value="Model.Nome" Label="Nome" Required="true" />
        <MudTextField @bind-Value="Model.Email" Label="Email" Required="true" />
        @* <MudTextField @bind-Value="Model.Password" Label="Senha" InputType="InputType.Password" />
        <MudTextField @bind-Value="Model.ConfirmPassword" Label="Confirmar Senha" InputType="InputType.Password" /> *@
        <MudTable Items="@Model.Systems">
            <HeaderContent>
                <MudTh>Sistema</MudTh>
                <MudTh>Perfil</MudTh>
            </HeaderContent>

            <RowTemplate>
                <MudTd>@context.Name</MudTd>
                <MudTd>
                    <MudSelect T="string"
                               Value="@context.Permissoes.FirstOrDefault()?.Name"
                               ValueChanged="@((string novoValor) => OnPerfilChanged(context, novoValor))"
                               Dense="true"
                               Margin="Margin.None"
                               Variant="Variant.Text"
                               Disabled="@(!context.Permissoes.Any())">
                        @foreach (var perfil in context.Permissoes)
                        {
                            <MudSelectItem T="string" Value="@perfil.Name">
                                @perfil.Name
                            </MudSelectItem>
                        }
                    </MudSelect>
                </MudTd>
            </RowTemplate>
        </MudTable>
    </DialogContent>

    <DialogActions>
        <MudButton OnClick="Cancel">Cancelar</MudButton>
        <MudButton Color="Color.Primary" OnClick="Submit">Salvar</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    IMudDialogInstance MudDialog { get; set; }

    [Parameter]
    public AuthUserViewModel Model { get; set; }

    private async Task Submit()
    {
        //await SalvarUsuario(Model);
        MudDialog.Close(DialogResult.Ok(Model));
    }

    private void OnPerfilChanged(SystemViewModel sistema, string novoValor)
    {
        var perfilSelecionado = sistema.Permissoes.FirstOrDefault(p => p.Name == novoValor);
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }
}
